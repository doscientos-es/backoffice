# ============================================================
# doscientos backoffice CRM - environment variables
# Copy to .env.local for local dev. In production set on Vercel.
# ============================================================

# --- Supabase (project: backoffice-doscientos, eu-west-1) ---
NEXT_PUBLIC_SUPABASE_URL= 
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF= 

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME= 

# --- Resend (email) ---
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_FROM_DOMAIN=doscientos.es

# --- OpenAI (lead scoring + AI assistant) ---
OPENAI_API_KEY=

# --- Verifactu / SIF (RD 1007/2023) ---
# Possible values: mock | test | prod
VERIFACTU_ENV=mock
VERIFACTU_NIF_EMISOR=
VERIFACTU_EMISOR_NAME=DOSCIENTOS DESARROLLO TECNOLOGICO, S.L.
VERIFACTU_CERT_P12_BASE64=
VERIFACTU_CERT_PASSWORD=
VERIFACTU_CERT_EXPIRES_AT=

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- Observability ---
LOG_LEVEL=info
