    "date-fns-tz": "^3.2.0",
    "fast-xml-parser": "^4.5.1",
    "google-auth-library": "^10.9.0",
    "lru-cache": "^11.0.2",
    "lucide-react": "^0.469.0",
    "marked": "^18.0.5",
    "next": "^16.2.0",
    "next-themes": "^0.4.4",
    "node-forge": "^1.3.1",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
