{
  "name": "backoffice-doscientos",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "prebuild": "node -e \"if(!process.env.CI) process.exit(1)\" || pnpm env:example",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF --schema public > lib/database.types.ts",
    "env:example": "tsx scripts/generate-env-example.ts",
    "google:smoke": "tsx scripts/google-smoke.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.8",
