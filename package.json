    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/node-forge": "^1.3.11",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.7",
